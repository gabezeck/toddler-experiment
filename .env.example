# Parlor - Multi-Agent Conversation Framework
# Copy this file to .env and fill in your API key.

# Required: API Key for your LLM provider.
#   OpenAI:         sk-...
#   OpenRouter:     sk-or-...
#   LM Studio:      lm-studio  (or any non-empty string — it's ignored locally)
OPENAI_API_KEY=sk-your-key-here

# Optional: Override the API base URL.
#   OpenRouter:  https://openrouter.ai/api/v1
#   LM Studio:   http://localhost:1234/v1
#   Ollama:      http://localhost:11434/v1
# If set here, it applies to ALL configs unless overridden in the YAML.
# OPENAI_BASE_URL=
