# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: Model Selection
# Default models: gpt-4 for agents, gpt-3.5-turbo for web-surfer
# Available options: gpt-4, gpt-4-turbo, gpt-3.5-turbo, etc.
OPENAI_MODEL=gpt-4

# Optional: Base URL for OpenAI API (for Azure or proxy)
# Leave empty to use default OpenAI endpoint
# OPENAI_BASE_URL=

# Optional: Custom temperature for agent responses (0.0 - 2.0)
# Default: 0.7
# AGENT_TEMPERATURE=0.7

# Optional: Maximum tokens per response
# Default: 1000
# MAX_TOKENS=1000
